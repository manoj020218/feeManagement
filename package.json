{
  "name": "feeflow-backend",
  "version": "2.0.0",
  "description": "FeeFlow – Privacy-first fee management app with MongoDB auth backend",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "dev:local": "node scripts/dev-local.js",
