# FeeFlow Server — Environment Variables Template
# Copy to .env (production) or .env.local (development)
# Fill in your actual values. NEVER commit .env or .env.local.

PORT=3001
NODE_ENV=production

# ── MongoDB (split credentials — avoids URL encoding issues) ──
MONGODB_HOST=127.0.0.1
MONGODB_PORT=27017
MONGODB_DB=feeflow
MONGODB_USER=your_db_username
MONGODB_PASS=your_db_password
MONGODB_AUTH_DB=admin

# ── JWT Secrets ────────────────────────────────────────────
# Generate strong secrets:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_64_char_random_string
JWT_REFRESH_SECRET=replace_with_different_64_char_random_string

# ── Google OAuth (web client ID from Google Cloud Console) ─
GOOGLE_CLIENT_ID=your_project.apps.googleusercontent.com

# ── App ───────────────────────────────────────────────────
DEFAULT_COUNTRY=IN
APP_VERSION=1.0.0
APP_CHANGELOG=

# ── Analytics ─────────────────────────────────────────────
ANALYTICS_KEY=replace_with_random_key
