# FeeFlow — LOCAL DEVELOPMENT overrides
# Copy to .env.local and fill in your values.
# This file is loaded on top of .env when NODE_ENV=development.

NODE_ENV=development
PORT=3001

# ── VPS SSH tunnel (used by: npm run dev:local) ────────────
VPS_HOST=your.vps.ip.address
VPS_USER=root
VPS_PASS=your_ssh_password

# ── MongoDB — via SSH tunnel ──────────────────────────────
MONGO_URI_LOCAL=mongodb://127.0.0.1:27017/feeflow
MONGODB_USER=your_db_username
MONGODB_PASS=your_db_password
MONGODB_AUTH_DB=admin

# ── JWT (simpler values OK for local dev) ─────────────────
JWT_SECRET=local-dev-jwt-secret
JWT_REFRESH_SECRET=local-dev-refresh-secret

# ── App ───────────────────────────────────────────────────
DEFAULT_COUNTRY=IN
GOOGLE_CLIENT_ID=your_project.apps.googleusercontent.com
APP_VERSION=1.0.0
ANALYTICS_KEY=dev-key
